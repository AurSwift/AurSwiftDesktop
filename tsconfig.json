{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./packages/renderer/src/*"],
      "@app/main": ["./packages/main/src"],
      "@app/preload": ["./packages/preload/src"]
    }
  },
  "include": ["tests/**/*.ts", "tests/**/*.tsx"]
}
